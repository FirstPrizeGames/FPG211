{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/settings",
      "destination": "/settings/index.html"
    },
    {
      "source": "/Creator",
      "destination": "/Creator/index.html"
    },
    {
      "source": "/Pricing",
      "destination": "/Pricing/index.html"
    },
    {
      "source": "/Bio",
      "destination": "/Bio/index.html"
    },
    {
      "source": "/about",
      "destination": "/about/index.html"
    },
    {
      "source": "/About",
      "destination": "/about/index.html"
    },
    {
      "source": "/FAQ",
      "destination": "/FAQ/index.html"
    },
    {
      "source": "/feedback",
      "destination": "/feedback/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy/index.html"
    },
    {
      "source": "/license",
      "destination": "/license/index.html"
    },
    {
      "source": "/offline",
      "destination": "/offline/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
